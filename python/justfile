# List available commands
default:
    @just --list

# Install all dependencies
setup: library-setup component-setup

# Build the WASM component
build: component-build

# Run all tests
test: library-test component-test

# Run all formatter and lint gates
lint: library-lint component-lint

# Run all tests with coverage
coverage: library-coverage component-coverage

# Remove generated outputs while preserving dependency state
clean: library-clean component-clean
    ./lifecycle.sh clean

# Remove generated outputs and setup artifacts
purge: library-purge component-purge
    ./lifecycle.sh purge

# Upgrade locked dependencies and regenerate lockfiles
update: library-update component-update

# Install library dependencies
library-setup:
    ./lifecycle.sh library-setup

# Install component dependencies
component-setup:
    ./lifecycle.sh component-setup

# Build the component WASM artifact
component-build:
    ./lifecycle.sh component-build

# Run library tests
library-test:
    ./lifecycle.sh library-test

# Run component tests
component-test:
    ./lifecycle.sh component-test

# Run library formatter and lint gates
library-lint:
    ./lifecycle.sh library-lint

# Run component formatter and lint gates
component-lint:
    ./lifecycle.sh component-lint

# Run library tests with coverage
library-coverage:
    ./lifecycle.sh library-coverage

# Run component tests with coverage
component-coverage:
    ./lifecycle.sh component-coverage

# Clean library build artifacts
library-clean:
    ./lifecycle.sh library-clean

# Clean component build artifacts
component-clean:
    ./lifecycle.sh component-clean

# Purge library setup artifacts
library-purge:
    ./lifecycle.sh library-purge

# Purge component setup artifacts
component-purge:
    ./lifecycle.sh component-purge

# Upgrade library locked dependencies
library-update:
    ./lifecycle.sh library-update

# Upgrade component locked dependencies
component-update:
    ./lifecycle.sh component-update
