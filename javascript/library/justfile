# List available commands
default:
    @just --list

# Install npm dependencies (Playwright comes from the Nix flake)
setup:
    ./lifecycle.sh setup

# Run contract tests across Node, Bun, Deno, Chromium, and WebKit
test:
    ./lifecycle.sh test

# Check formatting (prettier), lint (eslint, incl. ../test-support), and audit dependencies
lint:
    ./lifecycle.sh lint

# Run runtime matrix plus Node coverage (100% threshold)
coverage:
    ./lifecycle.sh coverage

# Remove generated outputs while preserving dependency state
clean:
    ./lifecycle.sh clean

# Remove generated outputs and setup artifacts
purge: clean
    ./lifecycle.sh purge

# Upgrade locked dependencies and regenerate the lockfile
update:
    ./lifecycle.sh update
