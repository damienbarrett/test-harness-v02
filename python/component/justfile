export UV_CACHE_DIR := env_var_or_default('UV_CACHE_DIR', '.cache/uv')

wit_dir := "../../common/wit"
output_wasm := "task-component.wasm"
bindings_dir := "bindings"

# List available commands
default:
    @just --list

# Install dependencies
setup:
    uv sync --locked --extra build --extra test

# Build the WASM component
#
# Emits the wit-bindgen-generated `wit_world` package to `bindings/` (a stable
# location, gitignored) so host tests can import the real bindings instead of
# mocking them away. The `componentize` step then bundles `src/` + `bindings/`
# into the WASM artifact.
build:
    #!/usr/bin/env bash
    set -euo pipefail
    rm -rf {{bindings_dir}}
    uv run --locked --extra build componentize-py \
      -d {{wit_dir}} -w task-component bindings {{bindings_dir}}
    uv run --locked --extra build componentize-py \
      -d {{wit_dir}} -w task-component componentize \
      -p src -p {{bindings_dir}} -s -o {{output_wasm}} app

# Run tests (builds first)
test: build
    uv run --locked --extra test pytest tests/ -v

# Run tests with coverage (builds first)
coverage: build
    uv run --locked --extra test pytest tests/ --cov --cov-report=term-missing

# Remove generated outputs while preserving dependency state
clean:
    rm -rf __pycache__ .pytest_cache .coverage htmlcov output tests/__pycache__ {{bindings_dir}} {{output_wasm}}

# Remove generated outputs and setup artifacts
purge: clean
    rm -rf .venv
