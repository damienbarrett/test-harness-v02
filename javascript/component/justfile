# List available commands
default:
    @just --list

# Install dependencies
setup:
    ./lifecycle.sh setup

# Build the WASM component and transpile for testing
build:
    ./lifecycle.sh build

# Run tests (builds first)
test: build
    ./lifecycle.sh test

# Check formatting (prettier), lint (eslint), and audit dependencies
lint:
    ./lifecycle.sh lint

# Run tests with coverage (builds first, 100% threshold)
coverage: build
    ./lifecycle.sh coverage

# Remove generated outputs while preserving dependency state
clean:
    ./lifecycle.sh clean

# Remove generated outputs and setup artifacts
purge: clean
    ./lifecycle.sh purge

# Upgrade locked dependencies and regenerate the lockfile
update:
    ./lifecycle.sh update
