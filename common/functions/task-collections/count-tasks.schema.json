{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "common/functions/task-collections/count-tasks.schema.json",
  "name": "count-tasks",
  "description": "Returns the count of tasks",
  "parameters": {
    "type": "object",
    "properties": {
      "tasks": {
        "type": "array",
        "items": { "$ref": "../../entities/task-schema.json" }
      }
    },
    "required": ["tasks"],
    "additionalProperties": false
  },
  "returns": {
    "type": "integer",
    "description": "The number of tasks",
    "minimum": 0,
    "maximum": 4294967295
  }
}
