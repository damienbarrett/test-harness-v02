# List available commands
default:
    @just --list

# Install dependencies
setup:
    ./lifecycle.sh setup

# Build the WASM components (one per WIT world)
build:
    ./lifecycle.sh build

# Run tests (builds first)
test: build
    ./lifecycle.sh test

# Check formatting and lint with warnings denied (builds first - bindings.rs is generated)
lint: build
    ./lifecycle.sh lint

# Run tests with coverage (100% threshold)
coverage:
    ./lifecycle.sh coverage

# Remove generated outputs while preserving dependency state
clean:
    ./lifecycle.sh clean

# Remove generated outputs and setup artifacts
purge: clean
    ./lifecycle.sh purge

# Upgrade locked dependencies and regenerate the lockfile
update:
    ./lifecycle.sh update
